{
  "name": "tesla-player-desktop",
  "version": "0.1.0",
  "description": "Tesla Player desktop app: embedded NestJS backend (offline), with optional sync to a remote server.",
  "author": "Clubelek",
  "license": "MIT",
  "main": "build/main.js",
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "dev": "npm run compile && ELECTRON_DEV=1 electron .",
    "dev:fork": "npm run compile && ELECTRON_START_BACKEND=1 electron .",
    "build:front": "VITE_BASE_URL= npm --prefix ../tesla-player run build",
    "build:back": "npm --prefix ../nest-backend run build",
    "stage": "node scripts/stage.mjs",
    "rebuild:native": "electron-rebuild -m resources/backend -w sqlite3",
    "dist": "electron-builder --linux --win",
    "build:electron": "npm run build:front && npm run build:back && npm run stage && npm run rebuild:native && npm run compile && npm run dist"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^22.10.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "light-my-request": "^6.6.0"
  }
}
